# Database URL with connection pool optimization
# connection_limit: Maximum number of connections in the pool (default: number of CPU cores * 2 + 1)
# pool_timeout: Maximum time to wait for a connection (default: 10s)
# connect_timeout: Maximum time to establish a connection (default: 5s)
DATABASE_URL=postgresql://admin:Zoea2025Secure@172.16.40.61:5432/main?connection_limit=10&pool_timeout=20&connect_timeout=10
JWT_SECRET=zoea-jwt-secret-2025-production
JWT_REFRESH_SECRET=zoea-refresh-secret-2025-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
PORT=3000

# Comma-separated list of browser origins allowed to call the API (required when not using *).
# Include every admin URL you use: local dev, IP:port, and production domain.
# Example:
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001,http://209.74.80.195:3015,https://admin.zoea.africa
# CORS_ORIGIN=
