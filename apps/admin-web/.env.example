# Nest API base URL (must include /api). Used by the browser (via axios) and by the
# server-side /api/health proxy. If this points at a host that is not running the Zoea
# API, or returns 404 for GET /api/health, the app will show the maintenance page.
#
# UI-only dev against hosted API:
# NEXT_PUBLIC_API_URL=https://zoea-africa.qtsoftwareltd.com/api
#
# Local Nest (default Nest port in this repo is 3000; run admin on another port, e.g. 3001):
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

NEXT_PUBLIC_API_URL=https://zoea-africa.qtsoftwareltd.com/api
