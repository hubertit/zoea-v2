# Zoea Admin — admin.zoea.africa → Next.js on host 3015.
# Production TLS: Let’s Encrypt via certbot (same as resolveit.rw / fabcafe.rw on 209.74.80.195).
#
# Initial deploy (HTTP only, then certbot rewrites this file):
#   sudo cp admin.zoea.africa.conf.example /etc/nginx/sites-available/admin.zoea.africa.conf
#   sudo ln -sf /etc/nginx/sites-available/admin.zoea.africa.conf /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d admin.zoea.africa --redirect --key-type ecdsa
#
# After certbot you should see (like resolveit.rw):
#   ssl_certificate /etc/letsencrypt/live/admin.zoea.africa/fullchain.pem;
#   ssl_certificate_key /etc/letsencrypt/live/admin.zoea.africa/privkey.pem;
#   include /etc/letsencrypt/options-ssl-nginx.conf;
#   ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
# Port 80 → 301 redirect to HTTPS (managed by Certbot).
#
# Renewal: same account as resolveit — /etc/letsencrypt/renewal/admin.zoea.africa.conf (authenticator = nginx).
# If HTTP-01 fails (e.g. Cloudflare proxy misconfigured), temporarily grey-cloud the record or fix origin routing.

# ----- Pre-certbot template (certbot will add 443 + edit 80) -----
server {
    listen 80;
    listen [::]:80;
    server_name admin.zoea.africa;

    location / {
        proxy_pass http://127.0.0.1:3015;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }
}
